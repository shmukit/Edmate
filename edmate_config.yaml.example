budget:
  max_daily_usd: 10.0
extraction_settings:
  engine: !!python/object/apply:content_gen.core.config_schema.ExtractionEngine
  - pdf_extract_kit
  max_question_number: 40
  min_question_number: 1
  question_detection_mode: !!python/object/apply:content_gen.core.config_schema.DetectionMode
  - balanced
hia_settings:
  default_resilience_target: High
  enabled: true
  generate_critique_exercises: true
  generate_variants: true
  variant_count: 3
learning_science:
  assessment_role_tagging:
    enabled: true
  bloom_taxonomy:
    enabled: true
    target_levels:
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Remember
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Understand
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Apply
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Analyze
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Evaluate
    - !!python/object/apply:content_gen.core.config_schema.BloomLevel
      - Create
  cognitive_load:
    enabled: true
    explanation_depth: !!python/object/apply:content_gen.core.config_schema.ExplanationDepth
    - full
  elaborative_interrogation:
    enabled: true
  formative_summative_tagging:
    default_role: formative
    enabled: true
  interleaving:
    enabled: true
  profile: default
  retrieval_practice:
    enabled: true
    generate_variants: false
  spaced_repetition:
    algorithm: !!python/object/apply:content_gen.core.config_schema.SRAlogrithm
    - sm2
    enabled: true
model_routing:
  extraction: gemini/gemini-1.5-pro
  generation: anthropic/claude-3-haiku
  validation: openai/gpt-4o
observability:
  litellm_callbacks:
  - opik
storage_settings:
  image_mode: !!python/object/apply:content_gen.core.config_schema.ImageMode
  - cdn
workspace:
  curriculums: []
  target_tables: []
