# Portable example — copy to edmate_config.yaml and customize.
# Do not use YAML tags like !!python/object; values are plain strings.

model_routing:
  extraction: "vertex_ai/gemini-2.5-flash"
  generation: "vertex_ai/gemini-2.5-flash"
  validation: "vertex_ai/gemini-2.5-flash"

budget:
  max_daily_usd: 20.0

storage_settings:
  image_mode: "base64"

extraction_settings:
  engine: "pdf_extract_kit"
  min_question_number: 1
  max_question_number: null
  question_detection_mode: "balanced"
  segmentation_preset: "bangladeshi"

observability:
  litellm_callbacks: ["opik"]

learning_science:
  profile: "default"
  bloom_taxonomy:
    enabled: true
    target_levels:
      - "Remember"
      - "Understand"
      - "Apply"
      - "Analyze"
      - "Evaluate"
      - "Create"
  spaced_repetition:
    enabled: true
    algorithm: "sm2"
  elaborative_interrogation:
    enabled: true
  cognitive_load:
    enabled: true
    explanation_depth: "full"
  retrieval_practice:
    enabled: true
    generate_variants: false
  interleaving:
    enabled: true
  formative_summative_tagging:
    enabled: true
    default_role: "formative"
  assessment_role_tagging:
    enabled: true

hia_settings:
  enabled: true
  default_resilience_target: "High"
  generate_critique_exercises: true
  generate_variants: true
  variant_count: 3

workspace:
  default_subject: "General"
  default_curriculum: "General"
  curriculums:
    - "General Curriculum"
  target_tables:
    - id: "questions"
      label: "Main Question Bank"
