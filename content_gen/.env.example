# Example .env file for content generation system
# Copy this to .env and fill in your credentials

# ===== Optional Image CDN Storage (Legacy/Optional) =====
# Not required when using base64 image mode + Postgres persistence.
# Only needed if you explicitly run CDN upload mode.
# AZURE_STORAGE_ACCOUNT_NAME=your_account_name_here
# AZURE_STORAGE_ACCOUNT_KEY=your_account_key_here
# AZURE_STORAGE_CDN_URL=https://cdn.edmate.com  # Optional: custom CDN domain

# ===== Database =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/edmate

# OR Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_service_role_key_here

# ===== LLM / BYOK Keys =====
# Primary provider-agnostic key consumed by the router/client examples:
# LITELLM_API_KEY=your_llm_api_key_here
#
# Optional provider-specific aliases (legacy/backward-compatible):
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Path to Google Service Account JSON (optional, for Vertex AI/Google Cloud mode)
# GOOGLE_APPLICATION_CREDENTIALS=credentials/gemini_creds.json
