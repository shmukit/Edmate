# Example .env file for content generation system
# Copy this to .env and fill in your credentials

# ===== Azure Blob Storage =====
AZURE_STORAGE_ACCOUNT_NAME=mpowerstorage1
AZURE_STORAGE_ACCOUNT_KEY=your_account_key_here
# AZURE_STORAGE_CDN_URL=https://cdn.edmate.com  # Optional: custom CDN domain

# ===== Database =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/edmate

# OR Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_service_role_key_here

# ===== API Keys (Future) =====
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Path to Google Service Account JSON (optional, for Vertex AI/Google Cloud mode)
# GOOGLE_APPLICATION_CREDENTIALS=credentials/gemini_creds.json
