# Example .env file for content generation system
# Copy this to .env and fill in your credentials

# ===== Cloudflare R2 Storage =====
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=edmate-diagrams
R2_PUBLIC_URL=https://cdn.edmate.com

# ===== AWS S3 Storage (Alternative) =====
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_S3_BUCKET=edmate-diagrams
# AWS_REGION=us-east-1

# ===== Database =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/edmate

# OR Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_service_role_key_here

# ===== API Keys (Future) =====
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
